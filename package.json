{
  "name": "@maxedapps/slidesls",
  "version": "1.0.0",
  "description": "Skill-guided slide design system for AI agents: art directions, slide archetypes with content contracts, motion by default, and taste-encoding lints — all as copyable vanilla HTML/CSS/JS.",
  "keywords": [
    "agents",
    "ai-agents",
    "claude",
    "css",
    "design-system",
    "html",
    "presentation",
    "registry",
    "slides"
  ],
  "homepage": "https://github.com/maxedapps/slidesls#readme",
  "bugs": {
    "url": "https://github.com/maxedapps/slidesls/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxedapps/slidesls.git"
  },
  "bin": {
    "slidesls": "bin/slidesls.mjs"
  },
  "files": [
    "bin",
    "src",
    "registry",
    "schemas",
    "scripts/visual-qa-report.mjs",
    "skills",
    "docs",
    "README.md",
    "PROJECT.md",
    "CHANGELOG.md",
    "LICENSE",
    "registry.json"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "serve:examples": "node scripts/serve-examples.mjs",
    "serve:deck": "node bin/slidesls.mjs preview",
    "validate:registry": "node bin/slidesls.mjs validate-registry",
    "validate:skills": "node bin/slidesls.mjs generate-catalog --registry-root . --check",
    "validate:examples": "node bin/slidesls.mjs validate-examples",
    "lint": "oxlint --no-error-on-unmatched-pattern",
    "lint:fix": "oxlint --fix --no-error-on-unmatched-pattern",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "check": "pnpm lint && pnpm fmt:check && pnpm test && pnpm validate:registry && pnpm validate:skills && pnpm validate:examples && pnpm cli:smoke",
    "test": "node --test tests/**/*.test.mjs",
    "cli:smoke": "node scripts/test-cli-smoke.mjs",
    "visual:gate": "node scripts/visual-gate.mjs",
    "pack:check": "pnpm check && SLIDESLS_RELEASE=1 node scripts/visual-gate.mjs && node scripts/check-pack-size.mjs && npm pack --dry-run"
  },
  "devDependencies": {
    "@fontsource-variable/bricolage-grotesque": "5.2.10",
    "@fontsource-variable/fraunces": "5.2.9",
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "@fontsource-variable/libre-franklin": "5.2.8",
    "@fontsource-variable/newsreader": "5.2.10",
    "@fontsource-variable/source-serif-4": "5.2.9",
    "@fontsource-variable/space-grotesk": "5.2.10",
    "lucide-static": "1.23.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "playwright-core": "1.61.1"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@11.9.0"
}
