{
  "name": "@maxedapps/slidesls",
  "version": "0.2.0",
  "description": "Agent-primary vanilla HTML/CSS/JS slide deck authoring CLI and registry.",
  "keywords": [
    "agents",
    "css",
    "html",
    "presentation",
    "registry",
    "slides"
  ],
  "homepage": "https://github.com/maxedapps/slidesls#readme",
  "bugs": {
    "url": "https://github.com/maxedapps/slidesls/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxedapps/slidesls.git"
  },
  "bin": {
    "slidesls": "bin/slidesls.mjs"
  },
  "files": [
    "bin",
    "src",
    "registry",
    "schemas",
    "skills",
    "docs",
    "README.md",
    "PROJECT.md",
    "LICENSE",
    "registry.json"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "serve:examples": "node scripts/serve-examples.mjs",
    "serve:deck": "node bin/slidesls.mjs preview",
    "validate:registry": "node bin/slidesls.mjs validate-registry",
    "validate:skills": "node bin/slidesls.mjs generate-catalog --registry-root . --check",
    "validate:examples": "node bin/slidesls.mjs validate-examples",
    "lint": "oxlint --no-error-on-unmatched-pattern",
    "lint:fix": "oxlint --fix --no-error-on-unmatched-pattern",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "check": "pnpm lint && pnpm fmt:check && pnpm test && pnpm validate:registry && pnpm validate:skills && pnpm validate:examples && pnpm cli:smoke",
    "test": "node --test tests/**/*.test.mjs",
    "cli:smoke": "node scripts/test-cli-smoke.mjs",
    "pack:check": "pnpm check && npm pack --dry-run"
  },
  "devDependencies": {
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@11.9.0"
}
