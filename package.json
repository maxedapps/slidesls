{
  "name": "slidesls",
  "version": "0.0.0",
  "private": true,
  "description": "Agent-primary vanilla HTML/CSS/JS slide deck authoring CLI and registry.",
  "bin": {
    "slidesls": "./bin/slidesls.mjs"
  },
  "files": [
    "bin",
    "src",
    "registry",
    "schemas",
    "skills",
    "docs",
    "README.md",
    "PROJECT.md",
    "registry.json"
  ],
  "type": "module",
  "scripts": {
    "serve:examples": "node scripts/serve-examples.mjs",
    "serve:deck": "node skills/ls-slides/scripts/serve-deck.mjs",
    "validate:registry": "node scripts/validate-registry.mjs",
    "validate:skills": "node skills/ls-slides/scripts/generate-catalog.mjs --registry-root . --check",
    "validate:examples": "node scripts/validate-examples.mjs",
    "lint": "oxlint --no-error-on-unmatched-pattern",
    "lint:fix": "oxlint --fix --no-error-on-unmatched-pattern",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "check": "pnpm lint && pnpm fmt:check && pnpm validate:registry && pnpm validate:skills && pnpm validate:examples && pnpm cli:smoke",
    "cli:smoke": "node scripts/test-cli-smoke.mjs"
  },
  "devDependencies": {
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@11.1.1"
}
