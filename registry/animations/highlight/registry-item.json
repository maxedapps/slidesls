{
  "name": "animations/highlight",
  "type": "ls:animation",
  "description": "Static or reveal-timed highlight emphasis.",
  "files": [
    {
      "path": "registry/animations/highlight/highlight.css",
      "type": "registry:style"
    }
  ],
  "registryDependencies": ["core/base", "animations/reveal"],
  "dependencies": [],
  "devDependencies": [],
  "docs": "registry/animations/highlight/README.md",
  "safeAnywhere": true,
  "agentRecommended": false,
  "authoring": {
    "classGroups": [
      {
        "base": "ls-highlight"
      },
      {
        "base": "ls-reveal-highlight"
      }
    ],
    "cssVariables": [
      "--ls-highlight-animation-duration",
      "--ls-highlight-animation-accent",
      "--ls-highlight-animation-spread",
      "--ls-highlight-static-spread"
    ],
    "usage": [
      "Use .ls-highlight for static emphasis.",
      "Use .ls-reveal.ls-reveal-highlight with data-step for timed reveal highlights."
    ]
  }
}
