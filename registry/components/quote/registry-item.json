{
  "name": "components/quote",
  "type": "ls:component",
  "description": "Quote slide component.",
  "files": [
    {
      "path": "registry/components/quote/quote.css",
      "type": "registry:style"
    }
  ],
  "registryDependencies": ["core/base"],
  "dependencies": [],
  "devDependencies": [],
  "docs": "registry/components/quote/README.md",
  "rootClass": "ls-quote",
  "safeAnywhere": true,
  "snippets": [
    {
      "label": "Basic quote",
      "path": "registry/components/quote/snippets/basic.html"
    }
  ],
  "authoring": {
    "classGroups": [
      {
        "base": "ls-quote",
        "elements": ["ls-quote__evidence", "ls-quote__source", "ls-quote__text"],
        "modifiers": ["ls-quote--lg"]
      }
    ],
    "cssVariables": [
      {
        "name": "--ls-quote-size",
        "default": "44px",
        "overrideSafe": true
      },
      {
        "name": "--ls-quote-indent",
        "default": "44px",
        "overrideSafe": true
      },
      {
        "name": "--ls-quote-rule-width",
        "default": "5px",
        "overrideSafe": true
      }
    ]
  },
  "agentLevel": "recommended",
  "tags": ["quote", "testimonial", "citation"],
  "useCases": ["Present a quote, testimonial, cited principle, or short attributed idea."]
}
