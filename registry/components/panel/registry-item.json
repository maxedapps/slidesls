{
  "name": "components/panel",
  "type": "ls:component",
  "description": "Standalone visual panel for grouped slide content.",
  "files": [
    {
      "path": "registry/components/panel/panel.css",
      "type": "registry:style"
    }
  ],
  "registryDependencies": ["core/base"],
  "dependencies": [],
  "devDependencies": [],
  "docs": "registry/components/panel/README.md",
  "rootClass": "ls-panel",
  "safeAnywhere": true,
  "agentRecommended": true,
  "snippets": [
    {
      "label": "Basic panel",
      "path": "registry/components/panel/snippets/basic.html"
    }
  ],
  "authoring": {
    "classGroups": [
      {
        "base": "ls-panel",
        "elements": ["ls-panel__title", "ls-panel__text"],
        "modifiers": ["ls-panel--muted", "ls-panel--accent", "ls-panel--center", "ls-panel--frame"]
      }
    ],
    "cssVariables": [
      "--ls-panel-gap",
      "--ls-panel-padding",
      "--ls-panel-border",
      "--ls-panel-bg",
      "--ls-panel-frame-min-block-size"
    ],
    "usage": ["Use muted/accent modifiers sparingly to create hierarchy."]
  }
}
