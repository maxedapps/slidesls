{
  "name": "components/callout",
  "type": "ls:component",
  "description": "Callout slide component.",
  "files": [
    {
      "path": "registry/components/callout/callout.css",
      "type": "registry:style"
    }
  ],
  "registryDependencies": ["core/base"],
  "dependencies": [],
  "devDependencies": [],
  "docs": "registry/components/callout/README.md",
  "rootClass": "ls-callout",
  "safeAnywhere": true,
  "agentRecommended": true,
  "snippets": [
    {
      "label": "Basic callout",
      "path": "registry/components/callout/snippets/basic.html"
    }
  ],
  "authoring": {
    "classGroups": [
      {
        "base": "ls-callout",
        "elements": [
          "ls-callout__icon",
          "ls-callout__body",
          "ls-callout__title",
          "ls-callout__text"
        ],
        "modifiers": ["ls-callout--with-icon"]
      }
    ],
    "dataAttributes": [
      {
        "name": "data-ls-tone",
        "values": ["success", "warning", "danger"]
      }
    ],
    "cssVariables": [
      "--ls-callout-accent",
      "--ls-callout-padding",
      "--ls-callout-title-size",
      "--ls-callout-text-size"
    ],
    "usage": [
      "Use data-ls-tone for semantic status callouts.",
      "Add .ls-callout--with-icon only when an .ls-callout__icon is present."
    ]
  }
}
