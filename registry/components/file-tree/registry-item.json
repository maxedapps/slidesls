{
  "name": "components/file-tree",
  "type": "ls:component",
  "description": "Static file and folder tree component for project structure slides.",
  "tags": ["technical", "files", "architecture", "project"],
  "files": [
    {
      "path": "registry/components/file-tree/file-tree.css",
      "type": "registry:style"
    }
  ],
  "registryDependencies": ["core/base"],
  "dependencies": [],
  "devDependencies": [],
  "docs": "registry/components/file-tree/README.md",
  "rootClass": "ls-file-tree",
  "safeAnywhere": true,
  "snippets": [
    {
      "label": "Basic file tree",
      "path": "registry/components/file-tree/snippets/basic.html"
    }
  ],
  "authoring": {
    "classGroups": [
      {
        "base": "ls-file-tree",
        "elements": ["ls-file-tree__item", "ls-file-tree__name", "ls-file-tree__meta"]
      }
    ],
    "dataAttributes": [
      {
        "name": "data-ls-density",
        "values": ["compact"]
      },
      {
        "name": "data-ls-kind",
        "values": ["folder", "file"],
        "scope": ".ls-file-tree__item"
      },
      {
        "name": "data-ls-state",
        "values": ["active"],
        "scope": ".ls-file-tree__item"
      }
    ],
    "cssVariables": ["--ls-file-tree-font-size", "--ls-file-tree-padding"],
    "usage": ["Use for short static project structures; keep nesting shallow for slide fit."]
  },
  "agentLevel": "advanced"
}
