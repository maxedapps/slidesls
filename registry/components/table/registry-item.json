{
  "name": "components/table",
  "type": "ls:component",
  "description": "Presentation-friendly table component.",
  "files": [
    {
      "path": "registry/components/table/table.css",
      "type": "registry:style"
    }
  ],
  "registryDependencies": ["core/base"],
  "dependencies": [],
  "devDependencies": [],
  "docs": "registry/components/table/README.md",
  "rootClass": "ls-table",
  "safeAnywhere": true,
  "agentRecommended": true,
  "snippets": [
    {
      "label": "Basic table",
      "path": "registry/components/table/snippets/basic.html"
    }
  ],
  "authoring": {
    "classGroups": [
      {
        "base": "ls-table",
        "elements": ["ls-table__caption", "ls-table__value", "ls-table__muted", "ls-table__note"]
      }
    ],
    "classes": ["ls-table-frame"],
    "dataAttributes": [
      {
        "name": "data-ls-density",
        "values": ["compact"]
      },
      {
        "name": "data-ls-variant",
        "values": ["striped", "plain"]
      },
      {
        "name": "data-ls-overflow",
        "values": ["clip"],
        "scope": ".ls-table-frame"
      }
    ],
    "cssVariables": [
      "--ls-table-cell-padding",
      "--ls-table-min-inline",
      "--ls-table-accent",
      "--ls-table-stripe-bg"
    ]
  }
}
