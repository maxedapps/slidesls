{
  "name": "components/timeline",
  "type": "ls:component",
  "description": "Reusable timeline component.",
  "files": [
    {
      "path": "registry/components/timeline/timeline.css",
      "type": "registry:style"
    }
  ],
  "registryDependencies": ["core/base"],
  "dependencies": [],
  "devDependencies": [],
  "docs": "registry/components/timeline/README.md",
  "rootClass": "ls-timeline",
  "safeAnywhere": true,
  "snippets": [
    {
      "label": "Basic timeline",
      "path": "registry/components/timeline/snippets/basic.html"
    }
  ],
  "authoring": {
    "classGroups": [
      {
        "base": "ls-timeline",
        "elements": [
          "ls-timeline__item",
          "ls-timeline__marker",
          "ls-timeline__body",
          "ls-timeline__meta",
          "ls-timeline__title",
          "ls-timeline__text"
        ]
      }
    ],
    "dataAttributes": [
      {
        "name": "data-ls-density",
        "values": ["compact"]
      },
      {
        "name": "data-ls-orientation",
        "values": ["horizontal"]
      },
      {
        "name": "data-ls-progress",
        "values": ["true"]
      }
    ],
    "cssVariables": ["--ls-timeline-gap", "--ls-timeline-marker-size", "--ls-timeline-accent"]
  },
  "agentLevel": "recommended"
}
