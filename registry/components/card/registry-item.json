{
  "name": "components/card",
  "type": "ls:component",
  "description": "Flat feature and explanation cards for slide content.",
  "files": [
    {
      "path": "registry/components/card/card.css",
      "type": "registry:style"
    }
  ],
  "registryDependencies": ["core/base"],
  "dependencies": [],
  "devDependencies": [],
  "docs": "registry/components/card/README.md",
  "rootClass": "ls-card",
  "safeAnywhere": true,
  "snippets": [
    {
      "label": "Basic card",
      "path": "registry/components/card/snippets/basic.html"
    }
  ],
  "authoring": {
    "classGroups": [
      {
        "base": "ls-card",
        "elements": ["ls-card__body", "ls-card__title", "ls-card__text"],
        "modifiers": ["ls-card--row", "ls-card--center"]
      }
    ],
    "cssVariables": [
      { "name": "--ls-card-padding", "default": "24px", "overrideSafe": true },
      { "name": "--ls-card-title-size", "default": "28px", "overrideSafe": true },
      { "name": "--ls-card-text-size", "default": "21px", "overrideSafe": true }
    ],
    "usage": [
      "Use for content blocks inside grids or stacks; give each card 2-4 sentences or a visual.",
      "Add ls-card--center only when a card sits in a stretched context (ls-grid--fill) and its content should center vertically."
    ]
  },
  "composition": {
    "contentDensity": ["balanced"],
    "layoutBehavior": "content-sized",
    "copyGuidance": "2-4 sentences or a visual per card; one-liner points fit components/icon-item better.",
    "avoidWhen": [
      "a grid of cards where each holds only a title plus one short sentence",
      "more than 4 cards in one grid"
    ],
    "alternatives": [
      { "when": "one-liner points", "use": "components/icon-item" },
      { "when": "4-6 short items in a grid", "use": "templates/icon-grid" }
    ]
  },
  "agentLevel": "recommended"
}
