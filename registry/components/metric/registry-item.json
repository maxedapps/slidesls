{
  "name": "components/metric",
  "type": "ls:component",
  "description": "Metric slide component.",
  "files": [
    {
      "path": "registry/components/metric/metric.css",
      "type": "registry:style"
    }
  ],
  "registryDependencies": ["core/base"],
  "dependencies": [],
  "devDependencies": [],
  "docs": "registry/components/metric/README.md",
  "rootClass": "ls-metric",
  "safeAnywhere": true,
  "agentRecommended": true,
  "snippets": [
    {
      "label": "Basic metric",
      "path": "registry/components/metric/snippets/basic.html"
    }
  ],
  "authoring": {
    "classGroups": [
      {
        "base": "ls-metric",
        "elements": ["ls-metric__label", "ls-metric__value", "ls-metric__delta"]
      }
    ],
    "dataAttributes": [
      {
        "name": "data-ls-compact",
        "values": ["true"]
      }
    ],
    "usage": ["Use for one prominent KPI or numeric proof point."]
  }
}
