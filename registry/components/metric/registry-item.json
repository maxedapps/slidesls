{
  "name": "components/metric",
  "type": "ls:component",
  "description": "KPI/stat primitive for one prominent number plus label.",
  "files": [
    {
      "path": "registry/components/metric/metric.css",
      "type": "registry:style"
    }
  ],
  "registryDependencies": ["core/base"],
  "dependencies": [],
  "devDependencies": [],
  "docs": "registry/components/metric/README.md",
  "rootClass": "ls-metric",
  "safeAnywhere": true,
  "snippets": [
    {
      "label": "Basic metric",
      "path": "registry/components/metric/snippets/basic.html"
    }
  ],
  "authoring": {
    "classGroups": [
      {
        "base": "ls-metric",
        "elements": ["ls-metric__label", "ls-metric__value", "ls-metric__delta"]
      }
    ],
    "dataAttributes": [
      {
        "name": "data-ls-compact",
        "values": ["true"]
      }
    ],
    "usage": ["Use for one prominent KPI or numeric proof point."]
  },
  "composition": {
    "contentDensity": ["sparse"],
    "layoutBehavior": "content-sized",
    "copyGuidance": "One number plus a short label; the value carries the slide.",
    "avoidWhen": ["narrative or multi-sentence content"],
    "alternatives": [
      {
        "when": "points need explanation",
        "use": "components/card"
      }
    ]
  },
  "agentLevel": "recommended",
  "tags": ["metric", "kpi", "stat"],
  "useCases": ["Show a KPI, stat, numeric proof point, or one prominent measurable outcome."]
}
