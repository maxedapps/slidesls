{
  "name": "components/image-card",
  "type": "ls:component",
  "description": "Image case-study card component.",
  "files": [
    {
      "path": "registry/components/image-card/image-card.css",
      "type": "registry:style"
    }
  ],
  "registryDependencies": ["core/base"],
  "dependencies": [],
  "devDependencies": [],
  "docs": "registry/components/image-card/README.md",
  "rootClass": "ls-image-card",
  "safeAnywhere": true,
  "snippets": [
    {
      "label": "Basic image card",
      "path": "registry/components/image-card/snippets/basic.html"
    }
  ],
  "authoring": {
    "classGroups": [
      {
        "base": "ls-image-card",
        "elements": [
          "ls-image-card__media",
          "ls-image-card__content",
          "ls-image-card__eyebrow",
          "ls-image-card__title",
          "ls-image-card__text",
          "ls-image-card__meta",
          "ls-image-card__badge",
          "ls-image-card__caption"
        ]
      }
    ],
    "dataAttributes": [
      {
        "name": "data-ls-variant",
        "values": ["plain", "cover"]
      },
      {
        "name": "data-ls-density",
        "values": ["compact"]
      },
      {
        "name": "data-ls-ratio",
        "values": ["square", "portrait"]
      }
    ],
    "cssVariables": ["--ls-image-card-aspect", "--ls-image-card-gap", "--ls-image-card-media-block"]
  },
  "agentLevel": "recommended",
  "tags": ["image", "screenshot", "case-study"],
  "useCases": ["Present a screenshot, case study, visual example, or image-led proof point."]
}
