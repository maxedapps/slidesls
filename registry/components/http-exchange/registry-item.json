{
  "name": "components/http-exchange",
  "type": "ls:component",
  "description": "Static request and response blocks for API walkthrough slides.",
  "tags": ["technical", "api", "http", "request", "response"],
  "files": [
    {
      "path": "registry/components/http-exchange/http-exchange.css",
      "type": "registry:style"
    }
  ],
  "registryDependencies": ["core/base"],
  "dependencies": [],
  "devDependencies": [],
  "docs": "registry/components/http-exchange/README.md",
  "rootClass": "ls-http-exchange",
  "safeAnywhere": true,
  "snippets": [
    {
      "label": "Basic HTTP exchange",
      "path": "registry/components/http-exchange/snippets/basic.html"
    }
  ],
  "authoring": {
    "classGroups": [
      {
        "base": "ls-http-exchange",
        "elements": [
          "ls-http-exchange__block",
          "ls-http-exchange__header",
          "ls-http-exchange__method",
          "ls-http-exchange__status",
          "ls-http-exchange__url"
        ]
      }
    ],
    "dataAttributes": [
      {
        "name": "data-ls-density",
        "values": ["compact"]
      },
      {
        "name": "data-ls-tone",
        "values": ["success", "warning", "danger"],
        "scope": ".ls-http-exchange__status"
      }
    ],
    "cssVariables": ["--ls-http-font-size", "--ls-http-padding", "--ls-http-max-block-size"],
    "usage": ["Use for compact static API request/response examples."]
  },
  "agentLevel": "advanced"
}
