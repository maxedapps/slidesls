{
  "name": "components/code-diff",
  "type": "ls:component",
  "description": "Compact static code-diff component for implementation change explanations.",
  "tags": ["technical", "code", "diff", "engineering"],
  "files": [
    {
      "path": "registry/components/code-diff/code-diff.css",
      "type": "registry:style"
    }
  ],
  "registryDependencies": ["core/base"],
  "dependencies": [],
  "devDependencies": [],
  "docs": "registry/components/code-diff/README.md",
  "rootClass": "ls-code-diff",
  "safeAnywhere": true,
  "agentRecommended": false,
  "snippets": [
    {
      "label": "Basic code diff",
      "path": "registry/components/code-diff/snippets/basic.html"
    }
  ],
  "authoring": {
    "classGroups": [
      {
        "base": "ls-code-diff",
        "elements": [
          "ls-code-diff__header",
          "ls-code-diff__body",
          "ls-code-diff__line",
          "ls-code-diff__number",
          "ls-code-diff__code",
          "ls-code-diff__marker"
        ]
      }
    ],
    "dataAttributes": [
      {
        "name": "data-ls-density",
        "values": ["compact"]
      },
      {
        "name": "data-ls-diff",
        "values": ["add", "remove", "focus"],
        "scope": ".ls-code-diff__line"
      }
    ],
    "cssVariables": [
      "--ls-code-diff-font-size",
      "--ls-code-diff-padding-block",
      "--ls-code-diff-max-block-size"
    ],
    "usage": ["Use for short static diffs; avoid dense, full-file excerpts on a slide."]
  }
}
