{
  "name": "components/divider",
  "type": "ls:component",
  "description": "Content divider component.",
  "files": [
    {
      "path": "registry/components/divider/divider.css",
      "type": "registry:style"
    }
  ],
  "registryDependencies": ["core/base"],
  "dependencies": [],
  "devDependencies": [],
  "docs": "registry/components/divider/README.md",
  "rootClass": "ls-divider",
  "safeAnywhere": true,
  "snippets": [
    {
      "label": "Basic divider",
      "path": "registry/components/divider/snippets/basic.html"
    }
  ],
  "authoring": {
    "classGroups": [
      {
        "base": "ls-divider",
        "elements": ["ls-divider__label"]
      }
    ],
    "dataAttributes": [
      {
        "name": "data-ls-density",
        "values": ["compact", "spacious"]
      },
      {
        "name": "data-ls-orientation",
        "values": ["vertical"]
      },
      {
        "name": "data-ls-variant",
        "values": ["accent", "dashed"]
      }
    ],
    "cssVariables": ["--ls-divider-color", "--ls-divider-thickness", "--ls-divider-gap"]
  },
  "agentLevel": "recommended"
}
