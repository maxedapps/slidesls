{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slidesls.dev/schemas/registry-item.schema.json",
  "title": "slidesls registry item",
  "description": "Documentation schema only. Runtime enforcement lives in src/validation/registry.mjs.",
  "type": "object",
  "required": [
    "name",
    "type",
    "description",
    "files",
    "registryDependencies",
    "dependencies",
    "devDependencies",
    "agentLevel"
  ],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "ls:core",
        "ls:utility",
        "ls:component",
        "ls:animation",
        "ls:preset",
        "ls:template",
        "ls:style",
        "ls:layout",
        "ls:archetype",
        "ls:motion",
        "ls:font",
        "ls:icons"
      ]
    },
    "status": {
      "type": "string",
      "description": "Lifecycle marker. preview items are hidden from default catalog output; absent means stable.",
      "enum": ["stable", "preview", "deprecated"]
    },
    "intent": {
      "type": "array",
      "description": "Narrative intents this item serves; drives catalog --intent discovery.",
      "items": {
        "type": "string",
        "enum": [
          "open",
          "close",
          "prove",
          "compare",
          "explain-process",
          "teach",
          "show-data",
          "show-code",
          "emphasize"
        ]
      }
    },
    "styles": {
      "type": "object",
      "description": "Per-style compatibility notes, keyed by style name (e.g. styles/editorial).",
      "additionalProperties": { "type": "string" }
    },
    "contract": {
      "type": "object",
      "description": "Content contract: slot name to count/word constraints (archetypes).",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "min": { "type": "integer", "minimum": 0 },
          "max": { "type": "integer", "minimum": 0 },
          "minWords": { "type": "integer", "minimum": 0 },
          "maxWords": { "type": "integer", "minimum": 0 },
          "maxChars": { "type": "integer", "minimum": 0 },
          "description": { "type": "string" }
        }
      }
    },
    "motion": {
      "type": "object",
      "description": "Recommended motion for this item.",
      "additionalProperties": false,
      "properties": {
        "default": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "icons": {
      "type": "object",
      "description": "Icon guidance for this item.",
      "additionalProperties": false,
      "properties": {
        "guidance": { "type": "string" },
        "suggested": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "styleAttribute": {
      "type": "string",
      "description": "For ls:style items: the data-ls-style value the style responds to."
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "useCases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "registryDependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "devDependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "docs": {
      "type": "string"
    },
    "rootClass": {
      "type": ["string", "null"]
    },
    "safeAnywhere": {
      "type": "boolean"
    },
    "agentLevel": {
      "type": "string",
      "enum": ["starter", "recommended", "advanced", "experimental"]
    },
    "styleTone": {
      "type": "string"
    },
    "pairsWith": {
      "type": "array",
      "items": { "type": "string" }
    },
    "themeAttribute": {
      "type": "string"
    },
    "structure": {
      "type": "object",
      "description": "Optional structural contract metadata for future generalized validators.",
      "additionalProperties": true
    },
    "composition": {
      "type": "object",
      "description": "Advisory density/composition guidance surfaced by catalog and inspect.",
      "additionalProperties": false,
      "properties": {
        "contentDensity": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["sparse", "balanced", "dense"]
          }
        },
        "useWhen": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "layoutBehavior": {
          "type": "string",
          "enum": ["content-sized", "fills-area", "fixed"]
        },
        "itemCountGuidance": {
          "type": "string"
        },
        "copyGuidance": {
          "type": "string"
        },
        "avoidWhen": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "alternatives": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["when", "use"],
            "additionalProperties": false,
            "properties": {
              "when": {
                "type": "string",
                "minLength": 1
              },
              "use": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "snippets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "path"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "authoring": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "classGroups": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["base"],
            "additionalProperties": false,
            "properties": {
              "base": {
                "type": "string",
                "minLength": 1
              },
              "elements": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "modifiers": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "rule": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "classes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "classMetadata": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["scopeType", "safeAnywhere"],
            "additionalProperties": false,
            "properties": {
              "scopeType": {
                "type": "string",
                "enum": [
                  "anywhere",
                  "within-slide",
                  "within-slide-inner",
                  "direct-child-of-slide-inner",
                  "within-constrained-area",
                  "centers-content-cluster"
                ]
              },
              "safeAnywhere": {
                "type": "boolean"
              },
              "description": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "dataAttributes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "values": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "scope": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "cssVariables": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "object",
                "required": ["name"],
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "default": {
                    "type": "string"
                  },
                  "overrideSafe": {
                    "type": "boolean"
                  }
                }
              }
            ]
          }
        },
        "attributes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "scope": {
                "type": "string",
                "minLength": 1
              },
              "value": {
                "type": "string"
              },
              "description": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "usage": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
