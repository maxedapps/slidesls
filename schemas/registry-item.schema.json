{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slidesls.dev/schemas/registry-item.schema.json",
  "title": "slidesls registry item",
  "type": "object",
  "required": [
    "name",
    "type",
    "description",
    "files",
    "registryDependencies",
    "dependencies",
    "devDependencies"
  ],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": ["ls:core", "ls:utility", "ls:component", "ls:animation", "ls:preset", "ls:template"]
    },
    "description": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "registryDependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "devDependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "docs": {
      "type": "string"
    },
    "rootClass": {
      "type": ["string", "null"]
    },
    "safeAnywhere": {
      "type": "boolean"
    },
    "agentRecommended": {
      "type": "boolean"
    },
    "snippets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "path"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "authoring": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "classGroups": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["base"],
            "additionalProperties": false,
            "properties": {
              "base": {
                "type": "string",
                "minLength": 1
              },
              "elements": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "modifiers": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "rule": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "classes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "dataAttributes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "values": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "scope": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "cssVariables": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "attributes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "scope": {
                "type": "string",
                "minLength": 1
              },
              "value": {
                "type": "string"
              },
              "description": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "usage": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
