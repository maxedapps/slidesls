{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "slidesls-manifest.schema.json",
  "title": "slidesls copied registry manifest",
  "type": "object",
  "required": ["schemaVersion", "cliVersion", "entry", "baseDir", "copiedFiles"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "cliVersion": { "type": "string" },
    "registrySource": { "type": "object" },
    "entry": { "type": "string" },
    "baseDir": { "type": "string" },
    "requestedItems": { "type": "array", "items": { "type": "string" } },
    "dependencyOrder": { "type": "array", "items": { "type": "string" } },
    "copiedFiles": { "type": "array" },
    "links": { "type": "array", "items": { "type": "string" } },
    "scripts": { "type": "array", "items": { "type": "string" } },
    "updatedAt": { "type": "string" }
  }
}
